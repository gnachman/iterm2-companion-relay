# Config for ops/deploy-vps.sh. Copy to ops/deploy.env, fill in, then run:
#
#   cp ops/deploy.env.example ops/deploy.env
#   $EDITOR ops/deploy.env
#   bash ops/deploy-vps.sh ops/deploy.env
#
# ops/deploy.env holds secrets (dashboard password, metrics push token) and is
# gitignored — keep it off shared hosts. Everything here can also be passed as
# real environment variables instead of a file.

# ── Required ──────────────────────────────────────────────────────────────────
# Public hostname clients connect to. Becomes RELAY_ORIGIN=https://<host> and the
# Caddy site name. MUST equal what devices use (it is bound into join transcripts
# and the App Attest clientDataHash). Create a DNS A record <host> -> this VPS's
# public IP before relying on TLS.
RELAY_ORIGIN_HOST=relay1.iterm2.com

# ── App Attest / admission (defaults are the iTerm2 production values) ─────────
APP_ID=H7V7XYVQ7D.com.googlecode.iterm2.companion
APPATTEST_ENV=production            # production | development
ATTEST_REQUIRED=true                # anything but "false" requires attestation

# ── Quotas ────────────────────────────────────────────────────────────────────
RELAY_DAILY_BYTE_QUOTA=8589934592   # per-room relayed bytes / rolling 24h (8 GiB)

# ── On-box dashboard (metrics UI at https://<host>/dashboard/) ────────────────
ENABLE_DASHBOARD=true
DASHBOARD_USER=admin
# SECRET. Leave blank to auto-generate a strong password (printed once at the end
# and stored in /etc/iterm2-relay-dashboard.env). A re-run reuses the existing one.
DASHBOARD_PASSWORD=

# ── Off-box metrics push (optional; leave blank to keep /metrics loopback-only) ─
# Both must be set to enable. The token must match the monitor Worker's
# INGEST_TOKEN secret. RELAY_METRICS_PUSH_TOKEN is a SECRET.
RELAY_METRICS_PUSH_URL=
RELAY_METRICS_PUSH_TOKEN=

# ── Source / paths (rarely changed) ───────────────────────────────────────────
REPO_URL=https://github.com/gnachman/iterm2-companion-relay
REPO_REF=main
# Set SRC_DIR to clone from a local checkout instead of REPO_URL (exact on-box
# source / offline). Leave blank to clone REPO_URL at REPO_REF.
SRC_DIR=
APP_DIR=/opt/iterm2-companion-relay

# ── Service accounts (which Unix user each service runs as) ────────────────────
# Leave BLANK to run under a systemd DynamicUser: a dedicated, ephemeral,
# locked-down account systemd manages for you (shown as the unit name, e.g.
# "iterm2-companion-relay"). This is not the invoking user.
#
# Set a name to run as a FIXED, named system account instead. The script creates
# it (system user, no login, no home) and rewrites the unit's DynamicUser=yes to
# User=/Group=<name>. Use two different names to keep the relay and dashboard
# isolated from each other (recommended).
RELAY_SERVICE_USER=
DASHBOARD_SERVICE_USER=

# ── Package install toggles (set false if the host is already provisioned) ─────
INSTALL_NODE=true
INSTALL_CADDY=true
