# Environment for the relay (install to /etc/iterm2-companion-relay.env).
# These are read by bin/relay.js and room.js. Keep this file 0600.

# --- Listener (localhost only; the reverse proxy terminates TLS) ---
RELAY_HOST=127.0.0.1
RELAY_PORT=8787
# SQLite state file. Under systemd StateDirectory this path is writable.
RELAY_DB=/var/lib/iterm2-companion-relay/relay.db

# --- Admission posture ---
# Fail-closed: anything other than "false" requires App Attest for fresh
# pairings. Established rooms always admit by signature regardless.
ATTEST_REQUIRED=true
# The app id the attestation verifier requires (team id + bundle id).
APP_ID=H7V7XYVQ7D.com.googlecode.iterm2.companion
# Accepted App Attest environment: "production" or "development".
APPATTEST_ENV=production
# This relay's canonical origin, bound into join transcripts and the App Attest
# clientDataHash. MUST equal the public origin clients use.
RELAY_ORIGIN=https://relay.iterm2.com

# --- Retention / quotas ---
# Established-room idle TTL in ms (default 30 days = 2592000000).
RELAY_ESTABLISHED_IDLE_TTL_MS=2592000000
# Per-room relayed-bytes cap per rolling 24h (code default 512 MiB = 536870912).
# 512 MiB is too tight for live terminal sharing (video stream + history tiles
# blow it in a single long session, tearing the room down with a 1008 "daily
# quota exceeded" close). Raised to 8 GiB; the relay sees only ciphertext, so
# this cap is purely abuse/cost protection. Left ACTIVE so a rebuilt env carries
# the higher value instead of silently falling back to the 512 MiB default.
RELAY_DAILY_BYTE_QUOTA=8589934592

# --- Diagnostics ---
# Off in production (no log retention / zero PII). Set to "true" only to stream
# opaque-tagged diagnostic lines to journald while debugging.
RELAY_LOG=false

# --- Proxy trust (set exactly ONE, matching your topology) ---
# Option A — behind a generic reverse proxy (Caddy) that authoritatively sets
# X-Forwarded-For (ops/Caddyfile forces it to the real peer). The relay then
# keys per-IP caps on XFF and IGNORES any client-supplied CF-Connecting-IP.
RELAY_TRUST_PROXY=true
#
# Option B — origin behind Cloudflare (CF sets CF-Connecting-IP and the origin
# firewall admits only CF). Use this INSTEAD of RELAY_TRUST_PROXY; the relay
# then keys per-IP caps on CF-Connecting-IP.
# RELAY_TRUST_CLOUDFLARE=true
#
# Enabling neither keys per-IP caps on the socket peer (correct only if the
# process is directly reachable with no proxy). Never enable a trust flag for a
# header a fronting proxy does not set authoritatively — that reopens per-IP-cap
# evasion.
#
# X-Forwarded-For is read from the right (the hop the proxy observed), safe for
# both replacing and appending proxies. If you chain N appending proxies, set:
# RELAY_TRUSTED_HOPS=1

# --- Single-process caps (optional; sensible defaults in host/server.js) ---
# RELAY_MAX_ROOMS=200000
# RELAY_MAX_SOCKETS_PER_IP=64
# RELAY_MAX_TOTAL_SOCKETS=200000
# RELAY_KEEPALIVE_MS=30000

# --- Off-box monitoring (outbound push; see monitor/) ---
# The relay POSTs an aggregate, PII-free snapshot to the monitor Worker on a
# timer instead of exposing /metrics to the internet. Both URL and token must be
# set to enable it; leave unset to keep /metrics loopback-only. The token must
# match the monitor's INGEST_TOKEN secret.
# RELAY_METRICS_PUSH_URL=https://iterm2-relay-monitor.<subdomain>.workers.dev/ingest
# RELAY_METRICS_PUSH_TOKEN=<shared secret, matches the monitor's INGEST_TOKEN>
# Push interval. Each push is one KV write on the monitor; on the free plan KV is
# capped at 1000 writes/day ACCOUNT-WIDE, so a 60s cadence (1440/day) overruns it
# and the monitor goes blind mid-day with "KV put() limit exceeded". 240000 (4
# min) = 360 writes/day, well under the cap. Keep the monitor's STALE_MINUTES > 4.
# Left ACTIVE (not commented) so any env derived from this file carries the safe
# 4-min cadence by default; it is inert unless the URL+TOKEN above enable push.
RELAY_METRICS_PUSH_MS=240000
